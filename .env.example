# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=track_regions
DB_USER=postgres
DB_PASSWORD=postgres

# Backend
BACKEND_PORT=3001
# Runtime mode. Leave as development locally; production enables fail-fast config guards.
NODE_ENV=development

# =============================================================================
# Authentication
# =============================================================================

# JWT secret for signing tokens - MUST be changed in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=dev-secret-change-in-production

# Email promoted to admin on first run (required in production).
# Leave empty in dev: the first verified sign-up becomes admin.
ADMIN_EMAIL=

# Optional display name for the ADMIN_EMAIL account.
ADMIN_DISPLAY_NAME=

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional - leave empty to disable)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In (optional - TODO: untested, requires Apple Developer account)
# See docs/authentication.md for setup instructions
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Email (SMTP) (optional) - sends email-verification + notification mail.
# Leave empty in dev: verification links are printed to the backend logs
# (docker compose logs backend) instead of being emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =============================================================================

# Martin Vector Tile Server
MARTIN_PORT=3000

# OpenAI API (optional) - enables AI-assisted region grouping, descriptions,
# geocoding, and image matching. Leave EMPTY to disable AI features (the backend
# logs "AI features disabled" at startup). A non-empty value is treated as a
# real key, so don't leave a placeholder here. Get a key:
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Frontend
VITE_API_URL=http://localhost:3001
VITE_MARTIN_URL=http://localhost:3000
